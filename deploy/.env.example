# Copy to deploy/.env and adjust for the target environment.
DEPLOY_DOMAIN=rogue.example.com
DEPLOY_SERVER=root@203.0.113.10
DEPLOY_DNS_TARGET=203.0.113.10
DEPLOY_APP_DIR=/var/www/rogue
DEPLOY_CERTBOT_EMAIL=admin@example.com

# Optional: source shared secrets before deploy/.env. This file is not committed.
DEPLOY_SECRETS_FILE=$HOME/.secrets

# These can come from DEPLOY_SECRETS_FILE instead of being set directly here.
DEPLOY_CLOUDFLARE_ZONE_ID=${CLOUDFLARE_ZONE_ID:-}
DEPLOY_CLOUDFLARE_API_TOKEN=${CLOUDFLARE_API_TOKEN:-}

# Set to 1 if DNS is managed outside Cloudflare.
DEPLOY_SKIP_DNS=0

# Public resolvers to check when local DNS cache lags after creating a record.
DEPLOY_DNS_RESOLVERS="1.1.1.1 8.8.8.8"

# Build from a clean git ref by default so unrelated local WIP does not affect deploys.
# Use DEPLOY_BUILD_REF=working-tree only when intentionally deploying dirty changes.
DEPLOY_BUILD_REF=HEAD
DEPLOY_BUILD_DIR=deploy/.build-worktree
